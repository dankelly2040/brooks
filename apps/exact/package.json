{
  "name": "brooks-exact",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node ./scripts/link-exact.mjs",
    "dev": "bun run generate:routes && node node_modules/@exact/devtools/src/scripts/vite-cli.mjs --config vite.config.mjs",
    "build": "bun run generate:routes && bun run check:platform-splits && node node_modules/@exact/devtools/src/scripts/vite-cli.mjs build --config vite.config.mjs",
    "exact:web": "bun node_modules/@exact/server/src/cli.ts --config exact.web.config.mjs",
    "generate:routes": "bun run node_modules/@exact/devtools/src/scripts/generate-route-registries.ts --source-root src",
    "check:platform-splits": "bun run node_modules/@exact/devtools/src/scripts/check-platform-splits.ts --source-root src",
    "typecheck": "bun run generate:routes && bun run check:platform-splits && tsc --noEmit",
    "setup-mcp": "bun run node_modules/@exact/devtools/src/scripts/setup-mcp.ts"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.0"
  }
}
